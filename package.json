{
  "name": "js-sdk",
  "version": "0.1.0",
  "description": "Zero-dependency TypeScript SDK for the Zesty.io API. Single-file drop-in.",
  "type": "module",
  "main": "./dist/zesty-sdk.cjs",
  "module": "./dist/zesty-sdk.mjs",
  "types": "./dist/zesty-sdk.d.ts",
  "unpkg": "./dist/zesty-sdk.min.js",
  "jsdelivr": "./dist/zesty-sdk.min.js",
  "exports": {
    ".": {
      "types": "./dist/zesty-sdk.d.ts",
      "import": "./dist/zesty-sdk.mjs",
      "require": "./dist/zesty-sdk.cjs"
    }
  },
  "files": ["dist", "zesty-sdk.ts", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["zesty", "zesty.io", "cms", "headless", "sdk", "typescript"],
  "author": "Content.One",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/contentdotone/js-sdk.git"
  },
  "homepage": "https://github.com/contentdotone/js-sdk#readme",
  "bugs": {
    "url": "https://github.com/contentdotone/js-sdk/issues"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
